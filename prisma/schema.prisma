generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  phone     String
  password  String
  role      Role      @default(PASSENGER)
  agencyId  String?
  createdAt DateTime  @default(now())
  bookings  Booking[]
  driver    Driver?
  agency    Agency?   @relation(fields: [agencyId], references: [id])
}

model Station {
  id             String          @id @default(uuid())
  name           String
  city           String
  address        String?
  agencyStations AgencyStation[]
  routesFrom     Route[]         @relation("FromStation")
  routesTo       Route[]         @relation("ToStation")
}

model Agency {
  id             String          @id @default(uuid())
  name           String
  logo           String?
  email          String
  phone          String
  isApproved     Boolean         @default(false)
  agencyStations AgencyStation[]
  buses          Bus[]
  drivers        Driver[]
  routes         Route[]
  users          User[]
}

model AgencyStation {
  id            String  @id @default(uuid())
  agencyId      String
  stationId     String
  counterNumber String?
  isActive      Boolean @default(true)
  agency        Agency  @relation(fields: [agencyId], references: [id])
  station       Station @relation(fields: [stationId], references: [id])

  @@unique([agencyId, stationId])
}

model Bus {
  id          String     @id @default(uuid())
  agencyId    String
  plateNumber String     @unique
  capacity    Int
  busType     String?
  agency      Agency     @relation(fields: [agencyId], references: [id])
  schedules   Schedule[]
}

model Route {
  id            String     @id @default(uuid())
  agencyId      String
  fromStationId String
  toStationId   String
  distanceKm    Float?
  agency        Agency     @relation(fields: [agencyId], references: [id])
  fromStation   Station    @relation("FromStation", fields: [fromStationId], references: [id])
  toStation     Station    @relation("ToStation", fields: [toStationId], references: [id])
  schedules     Schedule[]

  @@unique([agencyId, fromStationId, toStationId])
}

model Schedule {
  id            String         @id @default(uuid())
  routeId       String
  busId         String
  driverId      String?
  departureTime DateTime
  arrivalTime   DateTime?
  price         Float
  status        ScheduleStatus @default(SCHEDULED)
  bookings      Booking[]
  bus           Bus            @relation(fields: [busId], references: [id])
  driver        Driver?        @relation(fields: [driverId], references: [id])
  route         Route          @relation(fields: [routeId], references: [id])
}

model Booking {
  id          String        @id @default(uuid())
  passengerId String
  scheduleId  String
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  passenger   User          @relation(fields: [passengerId], references: [id])
  schedule    Schedule      @relation(fields: [scheduleId], references: [id])
  payment     Payment?
  ticket      Ticket?
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?
  booking       Booking       @relation(fields: [bookingId], references: [id])
}

model Ticket {
  id          String    @id @default(uuid())
  bookingId   String    @unique
  qrCode      String    @unique
  isValidated Boolean   @default(false)
  validatedAt DateTime?
  booking     Booking   @relation(fields: [bookingId], references: [id])
}

model Driver {
  id            String     @id @default(uuid())
  userId        String     @unique
  agencyId      String
  licenseNumber String
  agency        Agency     @relation(fields: [agencyId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
  schedules     Schedule[]
}

enum Role {
  PASSENGER
  AGENCY_ADMIN
  DRIVER
  SYSTEM_ADMIN
}

enum ScheduleStatus {
  SCHEDULED
  BOARDING
  DEPARTED
  ARRIVED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  USED
  FLAGGED
}

enum PaymentMethod {
  MTN_MOBILE_MONEY
  AIRTEL_MONEY
  CARD
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
